#!/bin/sh

red="\033[1;31m"
fg_reset="\033[0m"

error() {
	printf "%b\n" "${red}$1${fg_reset}" 1>&2
}


utils="grim slurp wl-copy"
IFS=" "
for util in $utils; do
	! command -v $util && error "$util not found"
done
IFS=

bold="\033[1m"
reset="\033[m"
image_dir=$HOME/Pictures/Screenshots
image_path=$image_dir/Screenshot\ from\ $(date +%Y-%m-%d\ %H-%M-%S).png

! [ -d $image_dir ] && mkdir -p $image_dir

intent() {
	printf "copy\nsave" | mew
}

case $1 in
	select)
		region=$(slurp)
		[ $? != 0 ] && exit 1
		answer=$(intent)
		[ $answer = "copy" ] && echo $region | grim -g - - | wl-copy -t  image/png
		[ $answer = "save" ] && echo $region | grim -g - "$image_path"
		;;
	full)
		answer=$(intent)
		[ $answer = "copy" ] && grim - | wl-copy -t  image/png
		[ $answer = "save" ] && grim "$image_path"
		;;
	*)

		printf "%b\n%b\n" "${bold}screenshot${reset}: wrapper for grim"\
			"${bold}Usage${reset}: screenshot [select|full]" >&2
		exit
		;;
esac

