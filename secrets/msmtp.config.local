defaults
auth           on
tls            on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile        ~/.local/state/msmtp.log

account        accountname
host           youremail@example.com
port           smtp_port_number
tls_starttls   on
from           youremail@example.com
user           youremail@example.com
passwordeval  "pass show email | head -1"

account default: accountname
